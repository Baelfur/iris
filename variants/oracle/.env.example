ORACLE_HOST=your-oracle-host
ORACLE_PORT=1521
ORACLE_SERVICE=your-service-name
ORACLE_USER=your-username
ORACLE_PASSWORD=your-password

# Required (#107): one of local / git / db. See docs/user-guide/external-configuration.md.
CONFIG__SOURCE=local

# Required (#261): user-facing auth posture — one of jwt / gateway / open.
#   jwt     — the service validates inbound JWT against AUTH__JWKS_URL.
#   gateway — the service accepts any caller; assumes upstream gateway validated identity.
#   open    — the service accepts any caller, no upstream assumption (dev only; logs WARNING).
AUTH__MODE=gateway

# ─── Recommended for production (uncomment + set when deploying) ────────────
#
# Ceiling on $count. Default 10000. Set to 0 (explicit opt-out) for unbounded.
# MAX_PAGE_SIZE=10000
#
# Default true — data routes 401 without X-DB-Authorization (fail-closed against
# deployments where the service account has full data SELECT). Set false to allow
# pool-mode access for callers that don't supply passthrough creds.
# AUTH__REQUIRE_PASSTHROUGH=true
#
# Required for /admin/* endpoints. Unset → 401 on every admin call (fail-closed).
# Set to a long random secret for runbooks / CI-CD that need to call /admin/refresh-schema or /admin/reload-config.
# AUTH__ADMIN_TOKEN=
#
# Salted-HMAC redaction for usernames in error logs. With this set, usernames
# become user:<16-hex>; without it they become <redacted>. Recommended in production.
# LOG_USER_SECRET=
#
# Application brand identity. Cascades to the HTTP response header
# (X-{Slug}-Deployment), FastAPI / OpenAPI title, OTel service.name
# default, Kafka client.id default, and the `app` field on every JSON
# log record. Default "app" is neutral; set to whatever the surrounding
# product calls this layer. Rules: ^[A-Za-z][A-Za-z0-9-]{0,62}$
# (letters/digits/hyphens, no spaces — drops cleanly into header names).
# Examples: APP_NAME=iris (acronym brand), APP_NAME=resource-direct (kebab).
# APP_NAME=app
#
# Canonical instance identity. Threads through structured-log records,
# OTel service.name, X-{App}-Deployment header, /health body. Kubernetes-
# style identifier rules: ^[a-z][a-z0-9_-]{0,62}$ (lowercase, alnum +
# underscore + hyphen, max 63 chars; hyphens normalized to underscores
# only at the config-DB Postgres-identifier site).
# DEPLOYMENT_NAME=
#
# Error-body verbosity for driver errors. Default "terse" (no DB topology).
# "safe" = stable {code, message} for machine consumers; "verbose" = raw driver text (dev / inside trust perimeter only).
# ERROR_DETAIL=terse
